{
  "Urls": "http://localhost:5000;https://localhost:5001",
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ReverseProxy": {
    "Routes": {
      "restaurants_route": {
        "ClusterId": "restaurants_cluster",
        "Match": {
          "Path": "/restaurants/{**remainder}"
        },
        "Transforms": [
          { "PathPattern": "/api/restaurants/{**remainder}" }
        ]
      },
      "menu_route": {
        "ClusterId" : "restaurants_cluster",
        "Match": {
          "Path": "/menus/{**remainder}"
        },
        "Transforms": [
          { "PathPattern": "/api/restaurants/{**remainder}" }
        ]
      },
      "auth_route": {
        "ClusterId": "api_cluster",
        "Match": {
          "Path": "/auth/{**remainder}"
        },
        "Transforms": [
          { "PathSet": "/api/auth/{**remainder}" }
        ]
      },
      "orders_route": {
        "ClusterId": "api_cluster",
        "Match": {
          "Path": "/orders/{**remainder}"
        },
        "Transform": [
          {"PathSet": "/api/orders/{**remainder}"}
        ]
      },
      "carts_route": {
        "ClusterId": "api_cluster",
        "Match": {
          "Path": "/carts/{**remainder}"
        },
        "Transform": [
          {"PathSet": "/api/carts/{**remainder}"}
        ]
      }
    },
    "users_route": {
      "ClusterId": "api_cluster",
      "Match": {
        "Path": "/users/{**remainder}"
      },
      "Transform": [
        {"PathSet": "/api/users/{**remainder}"}
      ]
    },
    "Clusters": {
      "restaurants_cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5251"
          }
        }
      },
      "api_cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5138"
          }
        }
      }
    }
  }
}
