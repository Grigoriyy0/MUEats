{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "Postgres": "Host=localhost;Port=5432;Username=postgres;Password=postgres;Database=mue.restaurants",
    "Redis": "localhost:6379,password=your_password_here"
  },
  "AuthOptions": {
    "Issuer": "mueats.server",
    "Audience": "mueats.client",
    "AccessTokenExpirationMinutes": 20,
    "RefreshTokenExpirationDays": 30,
    "PublicKeyPath": "."
  },
  "KafkaOptions": {
    "BootstrapServers": "localhost:9092",
    "ConsumerOptions": {
      "OrderCreatedEvent": {
        "Topic" : "orders.created"
      }
    }
  }
}
